{
  "manifest_version": 3,
  "key": "",
  "name": "KickClip",
  "version": "1.0.0",
  "description": "KickClip: save URLs and images with Cmd+Shift+S",
  "icons": {
    "16": "assets/icons/icon_16.png",
    "32": "assets/icons/icon_32.png",
    "48": "assets/icons/icon_48.png",
    "128": "assets/icons/icon_128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "tabs",
    "contextMenus",
    "windows",
    "sidePanel",
    "identity",
    "clipboardWrite",
    "cookies"
  ],
  "host_permissions": [
    "https://api-gstf2hxbiq-du.a.run.app/*",
    "https://api-hn4mxotviq-du.a.run.app/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://www.googleapis.com/*",
    "https://mail.naver.com/*",
    "https://*.naver.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "https://img.youtube.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "config.js",
        "html2canvas.bundle.js",
        "content-loader.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "config.js",
        "assets/icons/icon_16.png",
        "assets/icons/icon_32.png",
        "assets/icons/icon_48.png",
        "assets/icons/icon_128.png",
        "assets/favicons/google.png",
        "assets/favicons/naver.png",
        "brandConfig.js",
        "stateLite.js",
        "coreEngine.js",
        "itemDetector.js",
        "dataExtractor.js",
        "uiManager.js",
        "urlResolver.js",
        "coreEntry.js",
        "sidepanel.html",
        "sidepanel.js",
        "sidepanel.css",
        "firebase-bundle.js",
        "upload.js",
        "uploadStorage.js",
        "picker.html",
        "picker.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "save-url": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current URL or hovered image"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "oauth2": {
    "client_id": "108278020684-gc4o3rfjldhb5bvjo8fgm3shnbdj8j8c.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' data: https://api-gstf2hxbiq-du.a.run.app https://api-hn4mxotviq-du.a.run.app http://localhost:3000 http://localhost:3001 https://www.googleapis.com https://apis.google.com https://*.google.com https://*.googleusercontent.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; frame-src 'self' https://docs.google.com https://accounts.google.com https://*.google.com;"
  },
  "action": {
    "default_title": "KickClip",
    "default_icon": {
      "16": "assets/icons/icon_16.png",
      "32": "assets/icons/icon_32.png",
      "48": "assets/icons/icon_48.png",
      "128": "assets/icons/icon_128.png"
    },
    "default_popup": ""
  }
}
